# Application
NODE_ENV=development
PORT=3000

# Database
# Porta dedicada (não 5432) para evitar colisão com um Postgres nativo do SO
# escutando na porta padrão — ambos podem responder em "localhost" e nada
# garante que ferramentas do host conectem no container, não no nativo.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5433/biomapping_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=biomapping_dev
POSTGRES_PORT=5433

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars
